" --- appearance ---
set number
syntax on
set cursorline
set scrolloff=5
set showcmd
set laststatus=2

" --- behavior ---
set nocompatible
set backspace=indent,eol,start
set hidden
set encoding=utf-8

" --- indentation ---
set tabstop=4
set shiftwidth=4
set expandtab
set smartindent

" --- search ---
set incsearch
set hlsearch
set ignorecase
set smartcase

" --- completion ---
set wildmenu
set wildmode=longest:full,full
inoremap <C-Space> <C-n>
